# ─── Database ─────────────────────────────────────────────────────────────────
# Docker Compose sets this automatically to: postgresql://koc:koc123@db:5432/koc_db
# For local dev WITHOUT Docker (requires local Postgres running):
DATABASE_URL=postgresql://koc:koc123@localhost:5432/koc_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate your own: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NOTE: docker-compose.yml has a safe dev default — you don't need to set this for local testing
JWT_SECRET=koc_dev_secret_change_in_production_2026
JWT_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ─── Seed Credentials (also listed in README) ─────────────────────────────────
COACH_EMAIL=coach@koc.com
COACH_PASSWORD=Coach@123
STUDENT1_EMAIL=alice@koc.com
STUDENT1_PASSWORD=Student@123
STUDENT2_EMAIL=bob@koc.com
STUDENT2_PASSWORD=Student@123
STUDENT3_EMAIL=charlie@koc.com
STUDENT3_PASSWORD=Student@123
STUDENT4_EMAIL=diana@koc.com
STUDENT4_PASSWORD=Student@123
